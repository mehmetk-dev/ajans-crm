# Required environment variables for docker-compose
DB_USERNAME=crm_user
DB_PASSWORD=change-me
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Production / Coolify
APP_URL=https://crm.fogistanbul.com

# Google OAuth 2.0 (GA4 bağlantısı için)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://crm.fogistanbul.com/api/oauth/google/callback
FRONTEND_URL=https://crm.fogistanbul.com

# PageSpeed Insights (Web Tasarım analitik paneli için)
# https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# Optional
# CORS_ALLOWED_ORIGINS=https://crm.fogistanbul.com
# COOKIE_SECURE=true
# SWAGGER_ENABLED=false
